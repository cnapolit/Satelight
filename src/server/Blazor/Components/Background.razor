@using Server.Models.UserInterface
@implements IDisposable
@inject BrowseState BrowseState

<FadeImage FadeImageId="games-background" Img="@(BrowseState.SelectedGame?.Background ?? string.Empty)"/>

@code
{
    protected override void OnInitialized()
    {
        BrowseState.SelectedGameChanged += StateHasChanged;
    }

    public void Dispose()
    {
        BrowseState.SelectedGameChanged -= StateHasChanged;
    }
}